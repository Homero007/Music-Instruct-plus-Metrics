# Root del proyecto. Ajusta esta ruta segun tu maquina.
# macOS/Linux: /Users/tu_usuario/Downloads/hybrid_engine
# Windows: C:\Users\TuUsuario\Desktop\hybrid_engine
HYBRID_ENGINE_ROOT=/absolute/path/to/hybrid_engine

# Jobs: local para pruebas; celery para produccion con Redis.
HYBRID_ENGINE_JOB_BACKEND=local
HYBRID_ENGINE_REQUIRE_CELERY=0
HYBRID_ENGINE_BROKER_URL=redis://localhost:6379/0
HYBRID_ENGINE_RESULT_BACKEND=redis://localhost:6379/0

# Audio/render.
HYBRID_SOUNDFONT_PATH=assets/soundfonts/default.sf2
HYBRID_FLUIDSYNTH_BIN=fluidsynth
HYBRID_FFMPEG_BIN=ffmpeg
HYBRID_ENGINE_SAMPLE_RATE=48000
HYBRID_ENGINE_CHANNELS=2

# Reward model.
HYBRID_REWARD_DIR=data/models/reward/v1

# Metricas opcionales.
HYBRID_NEW_METRICS_AUTO=1
HYBRID_NEW_METRICS_REAL=data/datasets/jamendo/delivery_jamendo_150/audio
HYBRID_FAD_EXTRACTOR=mel

# Opcional si usas comando externo de render VST.
HYBRID_VST_RENDER_COMMAND=
